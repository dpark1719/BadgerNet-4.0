# Copy to .env (never commit .env).

# Path to Playwright storage state JSON after one-time browser login (local only).
# LINKEDIN_STORAGE_STATE=/absolute/path/to/linkedin_storage.json

# Optional: slow down automation (milliseconds between actions)
# LINKEDIN_THROTTLE_MS=800

# Optional: https://api.data.gov/signup/
# COLLEGE_SCORECARD_API_KEY=
